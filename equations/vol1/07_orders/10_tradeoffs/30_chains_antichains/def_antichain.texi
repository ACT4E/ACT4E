\begin{definition*}[Antichain in a poset]
    {}
    An \maindef{antichain} is a subset~$\subA$ of a \SY{poset} where no two distinct elements are comparable:
    \begin{equation*}{}
        \prfperiod{
            \posela, \poselb \setin \subA
        }{
            \posela \posAleq \poselb
        }{
            \posela = \poselb
        }
    \end{equation*}
\end{definition*}

\begin{lemma*}
    {}
    Consider~$\adpa,\adpb\setin \HomSet{\DP}{\F{\posgenA}}{\R{\posgenB}}$ and~$\adpc\setin \HomSet{\DP}{\F{\posgenC}}{\R{\posgenD}}$.
    We have
    \begin{equation*}
        (\adpa \dpjoin \adpb)
        \mtimescat \adpc=(\adpa \mtimescat \adpc) \dpjoin (\adpb\mtimescat \adpc).
    \end{equation*}
\end{lemma*}

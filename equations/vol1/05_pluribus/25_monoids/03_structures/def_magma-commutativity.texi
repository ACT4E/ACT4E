\begin{definition*}
    {}
    \SYNDEF{commutative magma}
    A \SY{magma}~$\sgrpA = \tup{\sgrpAset, \mtimes}$ is called \emph{commutative} (or: Abelian) if
    \begin{equation*}
        {}
        \sgrpela \mtimes \sgrpelb = \sgrpelb \mtimes \sgrpela,
    \end{equation*}
    for all~$\sgrpela, \sgrpelb \setin \sgrpAset$.
\end{definition*}

\begin{definition*}[Binary relation]
    {}
    A \maindef{binary relation} \relA from a set~\setA to a set~\setB is a subset of the \SY{cartesian product}~$\setA\cartprod \setB$:
    \begin{equation*}
        \relA \setsubseteq \setA \cartprod \setB.
    \end{equation*}
\end{definition*}

\begin{definition*}[Properties of a relation]
    {}
    \SYNDEF{injective relation}
    \SYNDEF{single-valued}
    \SYNDEF{everywhere-defined}
    \SYNDEF{surjective relation}
    We say that a relation~$\relA \colon \setA \mto \setB$ is:
    \begin{enumerate}
        \item {} \emph{Injective} if
              \begin{equation*}
                  \prfsemi{
                      \inrel \ela \relA \elb
                  }{
                      \inrel \elc \relA \elb
                  }{
                      \ela=\elc
                  }
              \end{equation*}
        \item {} \emph{Single-valued} if
              \begin{equation*}
                  \prfsemi{
                      \inrel \ela \relA \elb
                  }{
                      \inrel \ela \relA \eld
                  }{
                      \elb = \eld
                  }
              \end{equation*}
        \item {} \emph{Surjective} if for all~$\elb\setin \setB$ there exists an element~$\ela\setin \setA$ such that ~$\inrel{\ela}{\relA}{\elb}$;
        \item {} \emph{Everywhere-defined} if for all~$\ela\setin \setA$ there exists an element~$\elb \setin \setB$ such that $\inrel{\ela}{\relA}{\elb}$.
    \end{enumerate}
\end{definition*}

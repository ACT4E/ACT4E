\begin{definition*}[Injective function]{}
    A~$\mapa$ is said to be \emph{injective} if for all~$\ela_1, \ela_2 \setin\setA$
    \begin{equation*}
        {}
        \prfcomma{
            \mapa(\ela_1) = \mapa(\ela_2)
        }{
            \ela_1 = \ela_2
        }
    \end{equation*}
\end{definition*}

\begin{definition*}[Product of functions]
    {}
    \SYNDEF{product of functions}
    Given functions~$\mapa\colon \setA \sto \setB$ and~$\mapb\colon \setC \sto \setD$, their \emph{product} is the function:
    \begin{equation*}
        \defmapperiod{
            \mapa \funcprod \mapb
        }{
            \setA \cartprod \setC
        }{
            \sto
        }{
            \setB\cartprod \setD
        }{
            \tup{\setAel, \setCel}
        }{
            \tup{\mapa(\setAel),\mapb(\setCel)}
        }
    \end{equation*}
\end{definition*}

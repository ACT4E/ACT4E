\begin{definition*}[Composition of functions]
    {}
    \SYNDEF{composition of functions}
    Given functions~$\mapa\colon \setA \sto \setB$ and~$\mapb \colon \setB \sto \setC$, we denote their \emph{composition} by
    \begin{equation*}
        {}
        \defmapperiod{
            \mapa \mthen \mapb
        }{
            \setA
        }{
            \sto
        }{
            \setC
        }{
            \ela
        }{
            \mapb(\mapa(\ela))
        }
    \end{equation*}
\end{definition*}

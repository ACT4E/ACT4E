\begin{definition*}[Disjoint union of sets]
    {}
    Given sets~\setA and~\setB, their \SY{disjoint union} is the set
    \begin{equation*}
        \setA \setdisunion \setB \definedas ( \makeset{ 1 } \cartprod \setA) \setunion ( \makeset{2} \cartprod \setB).
    \end{equation*}
\end{definition*}

\begin{definition*}[Downward closed set]
    {}
    An \SY{upper set}~$\subA$ is \maindef{downward-closed} in a poset~\posA if
    \begin{equation*}
        \subA = \upit \Min \subA.
    \end{equation*}
    The set of downward-closed \SY{upper sets} of~\posA is denoted~$\setOfDCUppersets \posA$.

\end{definition*}

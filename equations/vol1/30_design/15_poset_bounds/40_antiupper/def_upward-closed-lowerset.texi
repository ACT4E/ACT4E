\begin{definition*}[Upward closed set]
    {}
    A \SY{lower set}~$\subA$ is \maindef{upward-closed} in a poset~\posA if
    \begin{equation*}
        \subA = \downit \Max \subA.
    \end{equation*}
    The set of upward-closed \SY{lower sets} of~\posA is denoted~$\setOfUCLowersets \posA$.
\end{definition*}

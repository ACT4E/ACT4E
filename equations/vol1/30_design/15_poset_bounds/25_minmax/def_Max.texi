\begin{definition*}[Maximal elements]
    {}
    $\Max \colon \posPA \to \posAA$ is the map that sends a subset~$\subA$ of a \SY{poset} to the maximal elements of that subset (those elements~$\setAel \setin \subA$ such that~$\setAel \posgeqof\posA \setBel$ for all~$\setBel \setin \subA$).
    In formulas:
    \begin{equation*}
        \defmapperiodset{
            \Max
        }{
            \posPA
        }{
            \posAA
        }{
            \subA
        }{
            \makesett{
                \setCel\setin \subA\colon
                \vmiddle{
                    \prftree{
                        \setDel\setin \subA
                    }{
                        \setDel\posAgeq \setCel
                    }{
                        \setCel=\setDel
                    }
                }
            }
        }
    \end{equation*}
    Note that~$\Max(\subA)$ could be empty.
\end{definition*}

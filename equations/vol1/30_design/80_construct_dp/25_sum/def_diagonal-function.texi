\begin{definition*}[Diagonal function]
    {}
    Define the \maindef{diagonal function}~$\diag_\posA\colon \posA \to {\posA \Ptimes \posA}$:
    \begin{equation*}
        \begin{aligned}
            \diag_\posA \colon \posA & \to {\posA \Ptimes \posA}, \\
            \posAel                  & \mapsto \tup{\posAel, \posAel}.
        \end{aligned}
    \end{equation*}
\end{definition*}

\begin{definition*}[Category of real vector spaces]
    \SYNDEF{category of real vector spaces}
    {}
    The category \VectR of \SY{real vector spaces} is:
    \begin{enumerate}
        \item \emph{Objects}: all \SY{real vector spaces}.
        \item \emph{Morphisms}: $\HomSet{\VectR}{\Obja}{\Objb}$ is the set of real linear maps $\Obja \mto \Objb$.
        \item \emph{Composition}: the usual composition of linear maps.
        \item \emph{Identity morphisms}: for any \SY{real vector space} $\Obja = \tup{\stylesets{X}, +,{{ \cdot}}}$, the identity morphism $\catid_\Obja$ is given by the identity function $\stylesets{X} \to \stylesets{X}$.
    \end{enumerate}
\end{definition*}

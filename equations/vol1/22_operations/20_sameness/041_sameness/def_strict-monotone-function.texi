\begin{definition*}[Strict  monotone functions]
    {}
    A function~$\mapa\colon \reals \sto \reals$ is \maindef{strictly monotone} if for all~$\setAel,\setBel\setin \reals$:
    \begin{equation*}
        \prfperiod{\setAel < \setBel}{\mapa(\setAel)<\mapa(\setBel)}
    \end{equation*}
\end{definition*}

\begin{definition*}[Category of finite design problems \DPfinite]
    {}
    The category of \maindef{finite design problems} \DPfinite consists of the following constituents:
    \begin{enumerate}
        \item \emph{Objects}: The objects are \SY{posets}.
        \item \emph{Morphisms}: The morphisms are \emph{finite} \SY{design problems} (\cref{def:finite-design-problem}).
        \item \emph{Identity morphism}: The \SY{identity morphism}~$\dpidat\posgenA \colon \funposA \profto \resposA$ is as in \DP.
        \item \emph{Composition operation}: Given morphisms~$\adpa \colon  \funposA \profto \resposB$ and~$\adpb \colon \funposB \profto \resposC$, their composition~$\adpa \dpthen \adpb\colon \funposA\profto \resposC$ is as in \DP.
    \end{enumerate}
\end{definition*}

\begin{definition*}[Finitely-supported upper sets]
    {}
    Given a poset~\posA, we call an \SY{upper set}~$\subA \setin \uppersets \posA$ \maindef{finitely supported}
    if it can be written as the \SY{upper closure} of a finite \SY{antichain}:
    \begin{equation*}
        \subA = (\upit\RR), \text{ for } \RR \setin \antichains \posA, \cardof\RR < \infty.
    \end{equation*}

\end{definition*}

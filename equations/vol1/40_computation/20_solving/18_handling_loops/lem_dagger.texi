\begin{lemma*}
    {}
    Let~$\mora\colon\posA\Ptimes\posB\toinPos\posB$ be \SY{Scott continuous}.
    For each~$\ela\setin\posAset$, define the map
    \begin{equation*}
        \mora_{\ela}:\elb\mapsto \mora(\ela,\elb)
    \end{equation*}
    Then the map
    \begin{equation*}
        \mora^{\dagger}:\ela\mapsto\lfp(\mora_{\ela})
    \end{equation*}
    is \SY{Scott continuous}.
\end{lemma*}
